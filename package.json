{
  "name": "tranbot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-wasm-assets.mjs && node scripts/fix-electron-symlinks.mjs",
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "sidecar": "tsx watch src/sidecar/server.ts",
    "test:stt": "tsx src/sidecar/test-stt.ts",
    "test:server": "tsx src/sidecar/test-server.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "fmt": "prettier --write src",
    "fmt:check": "prettier --check src"
  },
  "main": "out/main/main.js",
  "license": "ISC",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "onnxruntime-node",
      "sharp"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@ricky0123/vad-web": "^0.0.30",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^40.6.1",
    "lucide-react": "^0.575.0",
    "onnxruntime-web": "^1.24.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
